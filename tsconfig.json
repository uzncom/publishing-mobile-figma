{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "allowJs": true,
    "checkJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["react", "react-native", "node"]
  },
  "include": [
    "App.js",
    "index.js",
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "android",
    "ios"
  ]
}
